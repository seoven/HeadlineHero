# Python 通用忽略
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
pip-wheel-metadata/

# 虚拟环境
venv/
env/
*.env
.conda/

# ========== 目录结构占位 ==========

# 维持目录结构：保留 .gitkeep 文件
!data/**/.gitkeep
!model/**/.gitkeep
!logs/.gitkeep

# 数据文件（忽略内容，但保留目录和.gitkeep）
data/raw_data/*
data/processed_data/*
data/divided_data/*

# 日志文件
logs/*
*.log

# 模型文件
model/pretrained_model/*
model/saved_model/*
*.pth
*.bin

# 操作系统文件
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/
*.bak
*.tmp

# 压缩包
*.zip
*.7z
*.tar.gz